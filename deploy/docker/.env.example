# Copy to .env before running docker compose in production.
# server host = managed public server/runtime.
# self-host = user's local worker/F5/runtime connected to the server.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app_data
REDIS_PASSWORD=change-me

SECRET_KEY=change-me-long-random-string
TOKEN_ENCRYPTION_KEY=change-me-fernet-key

BACKEND_URL=https://api.example.com
FRONTEND_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com

BOT_SERVICE_IMAGE=paidviewer/bot-service:CHANGE_ME
FRONTEND_IMAGE=paidviewer/frontend:CHANGE_ME
TTS_GATEWAY_IMAGE=paidviewer/tts-gateway:CHANGE_ME
F5_TTS_IMAGE=paidviewer/f5-tts-service:CHANGE_ME

TTS_GATEWAY_API_KEY=change-me
F5_TTS_SERVICE_API_KEY=change-me
TTS_INTERNAL_API_KEY=change-me
INTERNAL_SERVICE_JWT_SECRET=change-me

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://api.example.com/auth/twitch/callback
TWITCH_BOT_REDIRECT_URI=https://api.example.com/auth/twitch/bot/callback

VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://api.example.com/auth/vk/callback
VK_BOT_REDIRECT_URI=https://api.example.com/auth/vk/bot/callback

YOUTUBE_API_KEY=

DONATIONALERTS_CLIENT_ID=
DONATIONALERTS_CLIENT_SECRET=
DONATIONALERTS_REDIRECT_URI=https://api.example.com/donationalerts/callback

HUGGINGFACE_TOKEN=
ADMIN_USERS=
