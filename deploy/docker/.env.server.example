# Copy to /srv/paidviewer/env/.env on the VPS.

PAIDVIEWER_DATA_DIR=/srv/paidviewer

POSTGRES_USER=paidviewer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=paidviewer
REDIS_PASSWORD=change-me

# First VPS deploy builds this image locally via scripts/vps-deploy-smoke.sh.
BOT_SERVICE_IMAGE=paidviewer-server:local

SECRET_KEY=change-me-openssl-rand-hex-32
TOKEN_ENCRYPTION_KEY=change-me-fernet-key

BACKEND_URL=https://api.example.com
FRONTEND_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://api.example.com/auth/twitch/callback
TWITCH_BOT_REDIRECT_URI=https://api.example.com/auth/twitch/bot/callback
TWITCH_BOT_EXPECTED_LOGIN=pa1dviewer
# Optional but stronger: immutable numeric Twitch user ID for pa1dviewer.
TWITCH_BOT_EXPECTED_USER_ID=
BOT_TOKEN_AUTO_BOOTSTRAP_ENABLED=false

VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://api.example.com/auth/vk/callback
VK_BOT_REDIRECT_URI=https://api.example.com/auth/vk/bot/callback
VK_AUTH_BASE_URL=https://auth.live.vkvideo.ru/app/oauth2/authorize

YOUTUBE_API_KEY=

DONATIONALERTS_CLIENT_ID=
DONATIONALERTS_CLIENT_SECRET=
DONATIONALERTS_REDIRECT_URI=https://api.example.com/donationalerts/callback
DONATIONALERTS_WEBHOOK_SECRET=

ADMIN_USERS=

WORKER_CONTROL_SELF_HOST_ENABLED=true
WORKER_CONTROL_MANAGED_ENABLED=false
WORKER_AGENT_DEFAULT_F5_ENDPOINT_URL=http://127.0.0.1:8011

LOG_LEVEL=INFO
LOG_FILE_LEVEL=WARNING
LOG_FILE_MAX_BYTES=5242880
LOG_FILE_BACKUP_COUNT=5
ENABLE_JSON_LOGS=true
SECURITY_LOG_MAX_BYTES=5242880
SECURITY_LOG_BACKUP_COUNT=5
