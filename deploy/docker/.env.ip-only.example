# Copy to /srv/paidviewer/env/.env on the VPS.
# Replace YOUR_SERVER_IP and YOUR_VERCEL_APP_URL before starting.

PAIDVIEWER_DATA_DIR=/srv/paidviewer

# For IP-only deployment the backend must be reachable by Vercel.
BOT_SERVICE_BIND_IP=0.0.0.0
BOT_SERVICE_PORT=8000

POSTGRES_USER=paidviewer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=paidviewer
REDIS_PASSWORD=change-me

BOT_SERVICE_IMAGE=ghcr.io/ddenisroz/paidviewer-server:CHANGE_ME

SECRET_KEY=change-me-openssl-rand-hex-32
TOKEN_ENCRYPTION_KEY=change-me-fernet-key

# Public app URL is the Vercel URL, not the raw VPS IP.
BACKEND_URL=https://YOUR_VERCEL_APP_URL
FRONTEND_URL=https://YOUR_VERCEL_APP_URL
CORS_ORIGINS=https://YOUR_VERCEL_APP_URL

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://YOUR_VERCEL_APP_URL/auth/twitch/callback
TWITCH_BOT_REDIRECT_URI=https://YOUR_VERCEL_APP_URL/auth/twitch/bot/callback

VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://YOUR_VERCEL_APP_URL/auth/vk/callback
VK_BOT_REDIRECT_URI=https://YOUR_VERCEL_APP_URL/auth/vk/bot/callback
VK_AUTH_BASE_URL=https://auth.live.vkvideo.ru/app/oauth2/authorize

YOUTUBE_API_KEY=

DONATIONALERTS_CLIENT_ID=
DONATIONALERTS_CLIENT_SECRET=
DONATIONALERTS_REDIRECT_URI=https://YOUR_VERCEL_APP_URL/donationalerts/callback
DONATIONALERTS_WEBHOOK_SECRET=

ADMIN_USERS=

WORKER_CONTROL_SELF_HOST_ENABLED=true
WORKER_CONTROL_MANAGED_ENABLED=false
WORKER_AGENT_DEFAULT_F5_ENDPOINT_URL=http://127.0.0.1:8011

LOG_LEVEL=INFO
LOG_FILE_LEVEL=WARNING
ENABLE_JSON_LOGS=true
SECURITY_LOG_MAX_BYTES=5242880
SECURITY_LOG_BACKUP_COUNT=5
