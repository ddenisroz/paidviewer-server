# ==============================================================================
# bot_service/.env.example
# Full operator-facing env template.
# Keep this file as the source of truth for supported runtime/integration settings.
# Legacy compatibility aliases that are not recommended for new setups are omitted on purpose.
# Priority guide:
# - [Required] fill in every real environment
# - [Usually] needed for common product features / integrations
# - [Default OK] keep as-is unless you need custom behavior
# - [Advanced] change only if you know exactly why
# - [Rare] diagnostics / staging / troubleshooting only
# ==============================================================================

# --- [Required] Runtime mode ---
# development | production
ENVIRONMENT=development
# true = verbose errors/logs
DEBUG=true
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# --- [Required] Security ---
# Generate: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32
# Keep default unless you have a strong reason to change JWT algorithm.
ALGORITHM=HS256
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key

# --- [Required] Database ---
# PostgreSQL only for runtime
DATABASE_URL=postgresql://user:password@localhost:5432/bot_service_db

# --- [Usually] App URLs / network ---
BOT_SERVICE_HOST=0.0.0.0
BOT_SERVICE_PORT=8000
BACKEND_URL=http://localhost
FRONTEND_URL=http://localhost
# Comma-separated
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# --- [Usually] Core TTS upstreams ---
# Fill these when bot_service talks to gateway/F5.
TTS_GATEWAY_URL=http://localhost:8010
# Used by bot_service -> tts-gateway. Also acts as shared fallback for direct F5 upstream auth
# when provider-specific keys are empty.
TTS_GATEWAY_API_KEY=
F5_TTS_SERVICE_URL=http://localhost:8011
# Strongly recommended dedicated F5 upstream key. Direct F5 voice/admin endpoints may reject
# TTS_GATEWAY_API_KEY even when gateway-managed synthesis works.
# If empty, bot_service falls back to TTS_INTERNAL_API_KEY and then TTS_GATEWAY_API_KEY.
F5_TTS_SERVICE_API_KEY=
# Optional: local filesystem root of extracted F5 service (maintenance stats/cleanup only)
F5_TTS_STORAGE_ROOT=

# --- [Advanced] Inter-service auth / transport ---
# Optional shared fallback key for direct F5 upstream auth when provider-specific keys are not set.
TTS_INTERNAL_API_KEY=
# Internal service JWT settings are kept for non-TTS legacy integrations / staged migrations.
INTERNAL_SERVICE_JWT_ENABLED=true
INTERNAL_SERVICE_JWT_ISSUER=bot_service
INTERNAL_SERVICE_JWT_AUDIENCE_TTS=f5_tts
# Optional dedicated secret. If empty, SECRET_KEY is used.
INTERNAL_SERVICE_JWT_SECRET=
INTERNAL_SERVICE_JWT_TTL_SECONDS=120
# Optional mTLS for HTTPS internal service mesh
INTERNAL_SERVICE_MTLS_ENABLED=false
INTERNAL_SERVICE_CA_CERT_PATH=
INTERNAL_SERVICE_CLIENT_CERT_PATH=
INTERNAL_SERVICE_CLIENT_KEY_PATH=

# --- [Default OK] Local self-hosted TTS security guardrails ---
# bot_service will accept only these hosts/CIDRs for user-defined local endpoint URLs.
LOCAL_TTS_ALLOWED_HOSTS=localhost,127.0.0.1,::1,host.docker.internal,f5_tts,tts_service
LOCAL_TTS_ALLOWED_CIDRS=127.0.0.0/8,::1/128
WORKER_PAIRING_TOKEN_TTL_MINUTES=15
WORKER_POLL_TIMEOUT_SECONDS=20
WORKER_JOB_LEASE_SECONDS=120
WORKER_JOB_MAX_ATTEMPTS=3
WORKER_STALE_AFTER_SECONDS=90
WORKER_CONTROL_SELF_HOST_ENABLED=true
WORKER_CONTROL_MANAGED_ENABLED=true
WORKER_RESULT_TIMEOUT_SECONDS=90
WORKER_RESULT_POLL_INTERVAL_SECONDS=1
WORKER_RECONCILE_INTERVAL_SECONDS=15

# --- [Default OK] Message retention / housekeeping ---
CHAT_MESSAGES_DB_LIMIT_PER_USER=3000
CHAT_MESSAGES_DB_LIMIT_TOTAL=100000
CHAT_MESSAGES_RETENTION_DAYS=30

# --- [Default OK] Rate limiting ---
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=60
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LOGIN=5/15minute
RATE_LIMIT_TTS=30/minute
MAX_LOGIN_ATTEMPTS=10

# --- [Usually] Twitch OAuth (user login) ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost/auth/twitch/callback
TWITCH_BOT_REDIRECT_URI=http://localhost/auth/twitch/bot/callback
# Bot token is NOT stored in .env. Use /auth/twitch/bot/login (saved in DB bot_tokens).

# OAuth identities promoted to app admin on login. Use platform:id or platform:username.
ADMIN_USERS=twitch:75969278,twitch:yourchy,vk:20416992,vk:Zavtra_Zavod

# --- [Usually] VK OAuth (user login) ---
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=http://localhost/auth/vk/callback
VK_BOT_REDIRECT_URI=http://localhost/auth/vk/bot/callback
VK_AUTH_BASE_URL=https://auth.live.vkvideo.ru/app/oauth2/authorize
# Only for local troubleshooting with broken cert chain
VK_INSECURE_SSL=false
# Bot token is NOT stored in .env. Use /auth/vk/bot/login (saved in DB bot_tokens).

# --- [Usually] Product integrations ---
YOUTUBE_API_KEY=
DONATIONALERTS_CLIENT_ID=
DONATIONALERTS_CLIENT_SECRET=
DONATIONALERTS_REDIRECT_URI=http://localhost/donationalerts/callback
# Shared secret used by /api/drops/donationalerts/webhook (header/query secret)
DONATIONALERTS_WEBHOOK_SECRET=

# --- [Usually] External AI / voice APIs ---
# Google Cloud TTS / YouTube
GOOGLE_CLOUD_API_KEY=
# Optional fallback alias if some tooling still expects GOOGLE_TTS_API_KEY
GOOGLE_TTS_API_KEY=
# Optional for ADC quota project / x-goog-user-project
GOOGLE_CLOUD_PROJECT_ID=
# HuggingFace-hosted assets / upstream tooling
HUGGINGFACE_TOKEN=
# DeepSeek-backed features
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- [Default OK] Chat analysis behavior ---
CHAT_ANALYSIS_CHANNEL_LIMIT=80
CHAT_ANALYSIS_GLOBAL_LIMIT=200
CHAT_ANALYSIS_MIN_MESSAGES=10
CHAT_ANALYSIS_OUTPUT_MAX_CHARS=150
CHAT_ANALYSIS_SAVE_RESULTS=false

# --- [Rare] Analysis diagnostics ---
# Optional verbose LLM-analysis logging toggle
ANALYSIS_MODE=false

# --- [Usually] Redis / background infrastructure ---
# REDIS_URL is commonly needed.
# CELERY_* are compatibility/runtime hooks; keep defaults unless you run Celery separately.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- [Default OK] Legacy fallback voice ---
# gTTS TLD: com, co.uk, com.au, ru, ...
GTTS_VOICE=com

# --- [Default OK] Logging ---
LOG_FILE=logs/bot_service.log
LOG_FILE_LEVEL=WARNING
LOG_FILE_MAX_BYTES=5242880
LOG_FILE_BACKUP_COUNT=5
ENABLE_JSON_LOGS=false
ENABLE_LOG_ROTATION=true

# --- [Rare] Sentry / error tracking ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=bot_service@0.03
SENTRY_DEBUG=false

# --- [Rare] Testing / local-only toggles ---
TESTING=false

# --- [Default OK] Bot token auto-bootstrap ---
# Leave these as-is unless you want to harden or disable auto-bootstrap behavior.
BOT_TOKEN_AUTO_BOOTSTRAP_ENABLED=true
BOT_TOKEN_AUTO_BOOTSTRAP_ADMIN_ONLY=true
BOT_TOKEN_AUTO_BOOTSTRAP_REQUIRE_REFRESH_TOKEN=false
